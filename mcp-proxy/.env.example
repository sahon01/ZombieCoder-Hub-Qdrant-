# Server
PORT=5000
# Public base URL (used for landing page / inspector links)
MCP_PROXY_BASE_URL=https://mcp.zombiecoder.my.id

# UAS Backend (where your real agent + APIs live)
UAS_BASE_URL=https://a.zombiecoder.my.id

# Auth toggle
# true  => proxy will send X-API-Key to backend and require UAS_API_KEY
# false => proxy will not send API key (useful for local testing)
MCP_PROXY_REQUIRE_API_KEY=true

# Backend API key (only needed when MCP_PROXY_REQUIRE_API_KEY=true)
UAS_API_KEY=change_me_to_a_strong_key
