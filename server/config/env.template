# Copy keys you need into server/.env or your process environment.
# Do not commit real secrets.

# --- Core ---
PORT=8000

# --- Admin ---
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change_me

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=zombiecoder

# --- RAG / Vector Backend ---
RAG_ENABLED=true
RAG_VECTOR_BACKEND=qdrant
RAG_TOP_K=6

# --- Qdrant ---
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=zombiecoder_metadata
QDRANT_VECTOR_SIZE=384

# Let the app spawn Qdrant automatically (recommended for no-docker local dev)
QDRANT_MANAGED=true

# Optional override. If empty, the app will auto-detect the bundled binary at:
# server/bin/qdrant/qdrant
# and will use server/config/qdrant.yaml
#QDRANT_RUNNER_CMD=

# --- llama.cpp fallback ---
LLAMA_CPP_FALLBACK_ENABLED=false
LLAMA_CPP_AUTO_START=false
LLAMA_CPP_HOST=127.0.0.1
LLAMA_CPP_PORT=15000
LLAMA_CPP_CONTEXT=4096
LLAMA_CPP_THREADS=4
#LLAMA_CPP_BIN_PATH=llama_cpp/bin/llama-server
#LLAMA_CPP_MODEL_PATH=llama_cpp/models/model.gguf
#LLAMA_CPP_EXTRA_ARGS=
