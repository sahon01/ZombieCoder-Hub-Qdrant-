package/
ex_ui/

# Chroma (local data + venv)
chroma_data/
chroma/
server/.chroma_venv/
server/.chroma_venv/**

# llama.cpp models (do not commit large gguf files)
**/*.gguf
llama_cpp/models/
server/llama_cpp/models/

# Cloudflared credentials (do not commit secrets)
**/.cloudflared/*.json
**/.cloudflared/*.pem

# DB exports
**/*.sqlite
**/*.sqlite3
**/*.db

# VSCode extension artifacts/caches (do not commit)
vscode-extension/%CD%/.npm-cache/
vscode-extension/**/.npm-cache/
vscode-extension/*.vsix
**/*.vsix
vscode-extension/**/_prebuilds/

# Accidental npm cache folders created under %CD% (do not commit)
%CD%/.npm-cache/
**/%CD%/.npm-cache/
server/%CD%/.npm-cache/
server/**/%CD%/.npm-cache/

# Archives & dumps
*.zip
*.sql

# Local exports
*.html
